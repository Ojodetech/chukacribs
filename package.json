{
  "name": "ChukaCribs",
  "version": "1.0.0",
  "description": "A student-focused accommodation website for Chuka.",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon index.js",
    "seed": "node scripts/seedDatabase.js",
    "backup:create": "node scripts/backupDatabase.js",
    "backup:list": "node scripts/listBackups.js",
    "backup:restore": "node scripts/restoreBackup.js",
    "migrate": "node scripts/migrations/runMigrations.js",
    "migrate:status": "node scripts/migrations/migrationStatus.js",
    "migrate:rollback": "node scripts/migrations/rollbackMigration.js",
    "migrate:create": "node scripts/migrations/createMigration.js",
    "test": "jest --detectOpenHandles --forceExit",
    "test:unit": "jest __tests__/models --detectOpenHandles --forceExit",
    "test:performance": "jest __tests__/performance --detectOpenHandles --forceExit",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --detectOpenHandles --forceExit",
    "test:ci": "node scripts/check-production-secrets.js && npm test -- --runInBand --silent",
    "lint": "eslint . --ext .js --ignore-path .gitignore",
    "lint:fix": "eslint . --ext .js --fix --ignore-path .gitignore",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@sentry/node": "^10.34.0",
    "axios": "^1.13.4",
    "bcryptjs": "^3.0.3",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^4.17.1",
    "express-async-errors": "^3.1.1",
    "express-async-handler": "^1.2.0",
    "express-rate-limit": "^8.2.1",
    "express-request-id": "^3.0.0",
    "express-validator": "^7.3.1",
    "fluent-ffmpeg": "^2.1.2",
    "helmet": "^8.1.0",
    "jaeger-client": "^3.19.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.3.3",
    "multer": "^2.0.2",
    "node-cron": "^4.2.1",
    "nodemailer": "^7.0.12",
    "prom-client": "^15.1.3",
    "rate-limit-redis": "^4.3.1",
    "redis": "^5.10.0",
    "sharp": "^0.33.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "tar": "^7.5.7",
    "uuid": "^13.0.0",
    "winston": "^3.19.0",
    "winston-loki": "^6.1.3"
  },
  "author": "Ojode Wycliffe",
  "license": "MIT",
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "eslint": "^8.55.0",
    "jest": "^30.2.0",
    "mongodb-memory-server": "^11.0.1",
    "nodemon": "^3.1.11",
    "pem": "^1.14.8",
    "prettier": "^3.1.1",
    "redis-mock": "^0.56.3",
    "selfsigned": "^5.5.0",
    "supertest": "^7.2.2"
  }
}
